---
import { profile, profiles } from '../data/site';
---
<section id="contact" class="container">
  <div class="reveal">
    <span class="eyebrow">Contact</span>
    <h2 class="section-title">Let's connect</h2>
    <p class="section-sub">
      Interested in firmware development, automotive tech, or just want to chat? Drop me a message.
    </p>
  </div>

  <div class="contact-wrap">
    <form
      class="contact-form reveal"
      action={`https://formsubmit.co/${profile.email}`}
      method="POST"
    >
      <input type="hidden" name="_subject" value="Portfolio inquiry" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_template" value="table" />

      <div>
        <label for="name">Your name</label>
        <input id="name" name="name" type="text" required autocomplete="name" placeholder="John Doe" />
      </div>
      <div>
        <label for="email">Your email</label>
        <input id="email" name="email" type="email" required autocomplete="email" placeholder="you@company.com" />
      </div>
      <div>
        <label for="msg">Message</label>
        <textarea id="msg" name="message" required placeholder="Hi Arun, I'd like to discuss..."></textarea>
      </div>
      <button type="submit" class="btn btn-primary" data-magnet>
        Send message <span class="arrow">→</span>
      </button>
    </form>

    <aside class="contact-aside reveal">
      <h3>Or reach out directly</h3>
      <p>I'm most responsive on email and LinkedIn. Happy to connect!</p>
      <div class="contact-links">
        <a class="contact-link" href={profile.socials.email}>
          <span>✉</span> {profile.email}
        </a>
        <a class="contact-link" href={profile.socials.linkedin} target="_blank" rel="noopener">
          <img src="/logos/linkedin.svg" alt="LinkedIn" /> LinkedIn
        </a>
        <a class="contact-link" href={profile.socials.github} target="_blank" rel="noopener">
          <img src="/logos/github.svg" alt="GitHub" /> GitHub
        </a>
        <a class="contact-link" href={profile.socials.leetcode} target="_blank" rel="noopener">
          <img src="/logos/leetcode.svg" alt="LeetCode" /> LeetCode
        </a>
      </div>
    </aside>
  </div>
</section>

<footer class="footer">
  <div class="container footer-row">
    <span>© <span data-year>2026</span> {profile.name}</span>
    <span>
      <a href={profile.socials.github} target="_blank" rel="noopener">GitHub</a> ·
      <a href={profile.socials.linkedin} target="_blank" rel="noopener">LinkedIn</a> ·
      <a href={profile.socials.leetcode} target="_blank" rel="noopener">LeetCode</a>
    </span>
  </div>
</footer>
