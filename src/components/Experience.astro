---
import { experience } from '../data/site';
---
<section id="experience" class="container">
  <div class="reveal">
    <span class="eyebrow">Experience</span>
    <h2 class="section-title">Where I've worked</h2>
    <p class="section-sub">
      3+ years across two semiconductor leaders — building firmware that ships in vehicles.
    </p>
  </div>

  <div class="timeline">
    {experience.map((e) => (
      <article class="exp-card reveal">
        <div class="exp-header">
          {e.logo && (
            <div class="exp-logo">
              <img src={e.logo} alt={e.company} />
            </div>
          )}
          <div class="exp-info">
            <h3 class="exp-company">{e.company}</h3>
            <div class="exp-role">{e.role}</div>
          </div>
          <div class="exp-meta">
            <div>{e.period}</div>
            <div>{e.location}</div>
          </div>
        </div>
        <p class="exp-summary">{e.summary}</p>
        <ul class="exp-list">
          {e.responsibilities.map((r) => <li>{r}</li>)}
        </ul>
        <div class="exp-stack">
          {e.stack.map((s) => <span class="chip">{s}</span>)}
        </div>
        {e.youtubeProjects && (
          <div class="exp-youtube">
            {e.youtubeProjects.map((yt) => (
              <a href={yt.url} target="_blank" rel="noopener" class="yt-link">{yt.title}</a>
            ))}
          </div>
        )}
      </article>
    ))}
  </div>
</section>
