---
import { projects } from '../data/site';
---
<section id="projects" class="container">
  <div class="reveal">
    <span class="eyebrow">Projects</span>
    <h2 class="section-title">What I've built</h2>
    <p class="section-sub">
      Key projects I've worked on — from security modules to network tooling and open-source contributions.
    </p>
  </div>

  <div class="proj-grid">
    {projects.map((p) => (
      <article class="proj-card reveal" data-spotlight>
        <div class="proj-tag">{p.tag}</div>
        <h3 class="proj-title">{p.title}</h3>
        <p class="proj-summary">{p.summary}</p>
        <div class="proj-foot">
          {p.stack.map((s) => <span class="chip">{s}</span>)}
          {p.link && <a class="btn" href={p.link} target="_blank" rel="noopener" style="margin-left:auto; padding: 0.4rem 0.8rem; font-size: 0.78rem;">View ↗</a>}
        </div>
      </article>
    ))}
  </div>
</section>
