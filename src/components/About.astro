---
import { profile } from '../data/site';
---
<section id="about" class="container">
  <div class="reveal">
    <span class="eyebrow">About</span>
    <h2 class="section-title">What I do</h2>
  </div>

  <div class="about-grid">
    <div class="prose reveal">
      <p>
        I'm a firmware engineer focused on <strong>automotive Ethernet switches</strong> —
        the networking silicon that connects Electronic Control Units (ECUs) in modern vehicles.
        My work spans from bare-metal driver development to system-level integration.
      </p>
      <p>
        At <strong>Infineon</strong>, I work on the eHSM (embedded Hardware Security Module),
        Ethernet drivers, PCI inter-core communication, PTP time synchronization, and 
        multi-module build systems across ARM R52 and AURIX cores. Everything is built with 
        ASPICE process compliance and validated with Cantata unit testing.
      </p>
      <p>
        Previously at <strong>Marvell</strong>, I developed an iperf application on the lwIP 
        TCP/IP stack, contributed patches to the open-source lwIP project, and worked on 
        automotive Ethernet PHY firmware validation and throughput optimization.
      </p>
      <p>
        I'm also passionate about IoT — I've published 6+ projects on Hackster.io and enjoy 
        solving DSA problems on LeetCode.
      </p>
    </div>

    <aside class="about-sidebar reveal">
      <div class="info-card">
        <h4>Contact</h4>
        <div class="info-row"><span class="icon">✉</span><a href={profile.socials.email}>{profile.email}</a></div>
        <div class="info-row"><span class="icon">📍</span><span>{profile.location}</span></div>
        <div class="info-row"><span class="icon">💼</span><span>Open to opportunities</span></div>
      </div>
      <div class="info-card">
        <h4>Core Expertise</h4>
        <div class="info-row"><span class="icon">⚡</span><span>Automotive Ethernet Switches</span></div>
        <div class="info-row"><span class="icon">🔒</span><span>eHSM / Security Firmware</span></div>
        <div class="info-row"><span class="icon">🔧</span><span>Linux & RTOS Drivers</span></div>
        <div class="info-row"><span class="icon">📡</span><span>PTP / Network Protocols</span></div>
        <div class="info-row"><span class="icon">🛠</span><span>ASPICE Process</span></div>
      </div>
    </aside>
  </div>
</section>
